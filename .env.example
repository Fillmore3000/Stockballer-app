# =============================================================
# ProSpect Mobile App - Environment Configuration
# =============================================================
# For Expo, prefix all variables with EXPO_PUBLIC_
# Copy this file to .env and fill in your values
# =============================================================

# Backend API URL
# Development: http://localhost:3001/api
# Production: https://api.prospect.io/api
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Contract Addresses (Base Sepolia Testnet)
EXPO_PUBLIC_VAULT_ADDRESS=
EXPO_PUBLIC_MOCK_USDC_ADDRESS=

# API-Football Key (optional - for direct stats fetching)
EXPO_PUBLIC_SPORTMONKS_API_KEY=
