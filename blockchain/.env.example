# Environment variables for Blockchain deployment
# Copy this file to .env and fill in your values
# NEVER commit .env files with real credentials!

# Database URL (if needed for scripts)
DATABASE_URL="postgresql://user:password@localhost:5432/prospect_dev"

# RPC URL for Base Sepolia
# Get from https://www.alchemy.com/ or https://www.infura.io/
RPC_URL="https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY"

# Deployer/Admin wallet private key - NEVER share this!
# This wallet needs ETH for gas on Base Sepolia
# Get testnet ETH from https://www.coinbase.com/faucets/base-ethereum-goerli-faucet
ADMIN_PRIVATE_KEY="your_deployer_wallet_private_key_here"

# BaseScan API Key for contract verification (optional)
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=""

# Deployed Contract Addresses (fill after deployment)
MOCK_USDC_ADDRESS="0x_deployed_mock_usdc_address"
VAULT_CONTRACT_ADDRESS="0x_deployed_vault_address"
